# Copier ce fichier vers .env à la racine du projet et renseigner les valeurs.
# Clé API : Brevo (ex-Sendinblue) → https://app.brevo.com → Paramètres → SMTP & API → Clés API.

SENDINBLUE_API_KEY=xkeysib-votre-cle-api-ici
SENDER_EMAIL=votre-expediteur-verifie@domaine.com

# URL publique du site (liens dans les e-mails)
NUTRISMART_PUBLIC_BASE=http://localhost/Esprit-PW-2A20-2026-NutriSmart-planRepas

